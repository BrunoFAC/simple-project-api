    "main": "index.js",
    "scripts": {
        "tsc": "tsc && tscpaths -p tsconfig.json -s ./src -o ./build",
        "dev": "set NODE_ENV=development&&set NODE_PATH=src/&& ts-node-dev --respawn --experimental-modules --transpile-only --watch src ./src/index.ts",
        "prod": "set NODE_PATH=build/&& dotenv -e .env node ./build/index.js",
        "sequelize": "node_modules/.bin/sequelize",
        "prettier:fix": "prettier --write \"src/**/*.{js,ts,tsx,json,md}\"",
        "prettier:check": "prettier --check \"src/**/*.{js,ts,tsx,json,md}\"",
        "lint": "eslint src",
        "eslint": "eslint .",
        "scaffold": "npx sequelize-auto -c sequelize-auto-config.json"
    },
    "author": "",
    "license": "ISC",
    "dependencies": {
