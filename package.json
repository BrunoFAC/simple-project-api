        "dotenv": "16.4.5",
        "ethers": "6.15.0",
        "express": "4.21.1",
        "express-async-errors": "3.1.1",
        "express-swagger-generator": "1.1.17",
        "jsonwebtoken": "9.0.2",
        "multer": "1.4.5-lts.1",
        "mysql2": "3.15.1",
